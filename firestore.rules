rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FONCTIONS DE SÉCURITÉ ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin(householdId) {
      return isSignedIn() &&
        request.auth.uid == get(/databases/$(database)/documents/households/$(householdId)).data.admin_uid;
    }

    function isMember(householdId) {
      return isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.member_uids;
    }

    function isAdminOrMember(householdId) {
      return isAdmin(householdId) || isMember(householdId);
    }

    // --- COLLECTION USERS (Pour les notifications) ---

    match /users/{userId} {
      // Un utilisateur peut lire et modifier uniquement son propre profil/token
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION HOUSEHOLDS ---

    match /households/{householdId} {
      // Lecture ouverte à tout utilisateur connecté pour permettre le flux d'invitation
      // (l'utilisateur scanne un QR code / reçoit un lien avec l'ID du foyer, puis lit
      // le document pour afficher le nom avant de rejoindre). L'ID du foyer joue le rôle
      // de token d'accès implicite — ne pas l'exposer publiquement.
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.admin_uid == request.auth.uid;

      // Membres/admin : peuvent modifier librement.
      // Cas "rejoindre le foyer" : l'utilisateur peut uniquement s'ajouter lui-même à
      // member_uids, sans retirer les membres existants ni modifier autre chose.
      allow update: if isAdminOrMember(householdId) ||
        (isSignedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['member_uids'])
          && request.resource.data.member_uids.hasAll(resource.data.member_uids)
          && request.resource.data.member_uids.size() == resource.data.member_uids.size() + 1
          && request.auth.uid in request.resource.data.member_uids
          && !(request.auth.uid in resource.data.member_uids));

      allow delete: if isAdmin(householdId);

      // Sous-collections (capteurs, historique de litière, etc.)
      match /{subcollection=**} {
        allow read, write: if isAdminOrMember(householdId);
      }
    }
  }
}
